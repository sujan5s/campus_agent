# Copy to .env and fill in. NEVER commit .env.

# --- LLM provider (see docs/03-TECH-STACK.md — swap provider here, never in code) ---
# For Google Gemini (default, free tier available):
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=AIza...your-key-from-aistudio.google.com...

# For Claude (Anthropic):
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-5
# ANTHROPIC_API_KEY=sk-...

# For GPT (OpenAI):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# For Llama (Ollama, fully offline, no key needed):
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# (first run: ollama pull llama3.1)

# --- Server ---
DEBUG=True
HOST=127.0.0.1
PORT=8000

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Persistence (defaults are fine for dev) ---
# DATABASE_URL=sqlite:///./campus.db
